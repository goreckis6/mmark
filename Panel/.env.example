# Skopiuj do .env i uzupełnij lokalnie (NIE commituj .env)

AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-8
PORT=8787

# Pierwsze konto admin (tworzone automatycznie gdy baza pusta)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=zmien_mnie

# Dodatkowe konta przy starcie serwera (Hostinger: ustaw w Environment variables)
# Format: login:haslo,login2:haslo2
# BOOTSTRAP_USERS=rekinybiznesu:twoje_haslo

# Opcjonalnie — tylko jeśli nie masz IAM role na serwerze
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
