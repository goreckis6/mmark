DirectoryIndex Panel/index.html index.html
Options -Indexes +FollowSymLinks

<IfModule mod_authz_core.c>
  Require all granted
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Root → panel (bez zewnętrznego 302, żeby nie gubić ścieżek)
  RewriteRule ^$ Panel/index.html [L]
  RewriteRule ^login\.html$ Panel/login.html [L]
</IfModule>
